NODE_ENV=development
HOST=0.0.0.0
PORT=3010

# AI database: read/write. Use a separate database on the existing MySQL instance.
AI_DATABASE_URL=mysql://bangcat_ai_app:change-me@127.0.0.1:3306/catnote_ai_dev
AI_DB_HOST=127.0.0.1
AI_DB_PORT=3306
AI_DB_USER=bangcat_ai_app
AI_DB_PASSWORD=change-me
AI_DB_NAME=catnote_ai_dev
AI_DB_CONNECTION_LIMIT=10

# Existing business database: SELECT-only account and approved views only.
SOURCE_DATABASE_URL=mysql://bangcat_ai_source_reader:change-me@127.0.0.1:3306/catnote_dev
SOURCE_DB_HOST=127.0.0.1
SOURCE_DB_PORT=3306
SOURCE_DB_USER=bangcat_ai_source_reader
SOURCE_DB_PASSWORD=change-me
SOURCE_DB_NAME=catnote_dev
SOURCE_DB_CONNECTION_LIMIT=5
SOURCE_DB_REQUIRED=false

# Internal calls should come from catnoteapi_v2, not directly from browsers or mini-programs.
INTERNAL_SERVICE_TOKEN=change-me-to-a-long-random-secret
DEFAULT_TENANT_ID=bangcat

REDIS_URL=redis://127.0.0.1:6379/0

# Tencent COS. Leave blank in local development; storage writes will be disabled.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PUBLIC_BASE_URL=

# Optional OpenTelemetry OTLP HTTP endpoint.
OTEL_SERVICE_NAME=bangcat-ai-platform
OTEL_EXPORTER_OTLP_ENDPOINT=
