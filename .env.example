# HTTP
HOST=127.0.0.1
PORT=3000

# Independent AI asset database. Do not point this at the production mini-program database.
AI_DATABASE_PATH=./data/bangcat-ai.sqlite

# Optional API key for write endpoints. Set a strong random value outside local development.
ADMIN_API_KEY=change-me

# Production source database settings are intentionally omitted until a read-only account,
# field allowlist and network boundary have been approved.
# SOURCE_DB_HOST=
# SOURCE_DB_PORT=
# SOURCE_DB_NAME=
# SOURCE_DB_READONLY_USER=
# SOURCE_DB_READONLY_PASSWORD=
